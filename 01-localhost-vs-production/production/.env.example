# ✅ Copy file này thành .env và điền giá trị thật
# ❌ KHÔNG BAO GIỜ commit file .env lên Git

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=development

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM — để trống sẽ dùng mock
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
MAX_TOKENS=500

# Security — bắt buộc khi ENVIRONMENT=production
AGENT_API_KEY=

# CORS — dấu phẩy phân cách
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com
